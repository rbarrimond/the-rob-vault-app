# =============================================================================
# .funcignore — Azure Functions deployment exclusions
#
# This file controls what is EXCLUDED from the published package sent to Azure.
# The goal is a lean runtime artifact: app source + .python_packages only.
#
# IMPORTANT: *.so is intentionally NOT excluded.
# Compiled native extension binaries (pyodbc, SQLAlchemy C extensions, etc.)
# live inside .python_packages and MUST be present for Azure to import them.
# Excluding *.so will silently break any C-extension dependency at cold start.
# =============================================================================

# CI-built package is shipped; virtual environments are never needed in Azure
.venv/
venv/
env/
ENV/
.env/

# Python bytecode — regenerated by the runtime, wastes package space
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python

# Tests and test tooling — not needed in Azure
tests/
pytest.ini
.pytest_cache/
.coverage
htmlcov/
coverage.xml
*.cover
.hypothesis/
.tox/
.nox/

# Documentation and project admin content
docs/
admin/
README.md
CHANGELOG.md

# CI / GitHub Actions
.github/

# Packaging metadata — not consumed by Azure runtime
pyproject.toml
*.egg-info/
*.egg
dist/
build/
/MANIFEST

# Local dev overrides and secrets
local.settings.json
tokens.json
*.pem
*.key
*.env
.env
.env.*
.env.local
.env.*.local

# Azurite local emulator state
.azurite/

# Editor / IDE
.vscode/
.idea/
*.sublime-workspace
*.sublime-project
*.code-workspace

# OS artifacts
.DS_Store
.Trash
.AppleDouble
.LSOverride
._*
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# Azure Functions build artifacts
bin/
obj/

# pyenv version pin (local dev only)
.python-version

# Node modules (if using any JavaScript/TypeScript)
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Local development
*.local

# Explicitly keep runtime package content that must be deployed.
!VaultSentinelPlatform/manifest/
!VaultSentinelPlatform/manifest/**